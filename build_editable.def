Bootstrap: docker
From: pytorch/pytorch:2.10.0-cuda12.8-cudnn9-runtime

# Don't forget to export APPTAINER_TMPDIR
# APPTAINER_TMPDIR=/home/shannc/Bio_SDD/build

%files
    # Only install project dependencies
    pyproject.toml /opt/pyproject.toml

%post
    apt-get update && apt-get install -y curl && rm -rf /var/lib/apt/lists/*
    curl -Lsf https://astral.sh/uv/install.sh | sh
    export PATH="/root/.local/bin:$PATH"
    uv pip install -r /opt/pyproject.toml --system --break-system-packages
    # Permits a system-wide install
    # to /root/.local/bin with uv

%environment
    export PATH="/root/.local/bin:$PATH" # Required to make the image container work
