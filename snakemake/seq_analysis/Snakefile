def is_pretrained(wc):
    return wc.get("sae") in env.saes["pretrained"]


rule get_activations:
    input:
        embeddings=branch(
            is_pretrained,
            then=rules.make_seq_dataset.output[0],
            otherwise=rules.get_embeddings.output[0],
        ),
        sae=branch(
            is_pretrained,
            then=None,
            otherwise=lambda wc: OUTDIR
            / f"saes_{wc.get('seqtype')}_{wc.get('level')}"
            / f"{wc.get('embedding_method')}-{wc.get('sae')}.pt",
        ),
    params:
        seqtype=lambda wc: wc.get("seqtype"),
        sae=lambda wc: wc.get("sae"),
        level=lambda wc: wc.get("level"),
        embedding_method=lambda wc: wc.get("embedding_method"),
        dataset_path=Path(DATASETS),
    output:
        directory(
            f"{DATASETS}/activations_{{seqtype}}_{{level}}/{{embedding_method}}-{{sae}}"
        ),


