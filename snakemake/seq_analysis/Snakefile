from pathlib import Path
import os


configfile: "env.yaml"


OUTDIR = Path(config["outdir"])
DATASETS = OUTDIR / "datasets"

os.environ["HF_HOME"] = config["huggingface"]

EMBEDDING_RES = config["resources"]["gpu40"]
EMBEDDING_RES["time"] = config.get("slurm_time_limit", "25-0:0:0")

embedding_methods = config["embedding_methods"]

embedded_datasets, activation_datasets, sae_dirs = [], [], []
for st in ("aa", "nuc"):
    if embedding_methods.get(st) and config["fastas"].get(st):
        cur_methods = embedding_methods[st].keys()
        embedded_datasets.extend(
            expand(f"{DATASETS}/embedded_{st}/{{method}}.completed", method=cur_methods)
        )
        for sae, spec in config["saes"].items():
            if spec["source"] != "custom":
                activation_datasets.append(
                    f"{DATASETS}/activations_{st}/{spec['embedding']}-{sae}-pretrained"
                )
            else:  # Custom SAEs to train up
                sae_dirs.extend(
                    expand(
                        f"{OUTDIR}/saes_{st}_{l}/{{m}}-{sae}",
                        m=cur_methods,
                        l=("tokens", "seqs"),
                    )
                )
                activation_datasets.extend(
                    expand(
                        f"{DATASETS}/activations_{st}_{{l}}/{{m}}-{sae}",
                        m=cur_methods,
                        l=("tokens", "seqs"),
                    )
                )


rule all:
    input:
        *[
            DATASETS / f"sequence_{st}"
            for st in ("aa", "nuc")
            if (files := config["fastas"].get(st)) is not None and len(files) > 1
        ],
        *embedded_datasets,
        # *activation_datasets, # [2026-04-11 Sat] TODO: set the SAEs up
        # *sae_dirs,


rule make_seq_dataset:
    params:
        seqtype=lambda wc: wc.get("seqtype"),
    output:
        directory(f"{DATASETS}/sequence_{{seqtype}}"),
    script:
        "main.py"


rule get_embeddings:  # NOTE: this saves them as an embedding cache
    input:
        rules.make_seq_dataset.output,
    params:
        seqtype=lambda wc: wc.get("seqtype"),
        embedding_method=lambda wc: wc.get("embedding_method"),
    resources:
        **EMBEDDING_RES,
    output:
        f"{DATASETS}/embedded_{{seqtype}}/{{embedding_method}}.completed",
    script:
        "main.py"



rule train_sae:
    input:
        rules.get_embeddings.output,
        f"{OUTDIR}/training_indices/{{level}}_{{seqtype}}.json",
    params:
        seqtype=lambda wc: wc.get("seqtype"),
        sae=lambda wc: wc.get("sae"),
        embedding_method=lambda wc: wc.get("embedding_method"),
        level=lambda wc: wc.get("level"),
        dataset_path=Path(DATASETS),
    output:
        f"{OUTDIR}/saes_{{seqtype}}_{{level}}/{{embedding_method}}-{{sae}}.pt",


rule label_coccurrence:
    input:
        config["metadata"]["file"],
    params:
        tmp_file=f"{OUTDIR}/label_cooccur_tmp.csv",
    output:
        f"{OUTDIR}/label_cooccurrence.csv",
        f"{OUTDIR}/cooccurence_stats.yaml",
    script:
        "main.py"


rule get_activations:
    input:
        embeddings=rules.get_embeddings.output,
        sae=branch(
            lambda wc: wc.get("embedding_method").endswith("-pretrained"),
            then=None,
            otherwise=lambda wc: OUTDIR
            / f"saes_{wc.get('seqtype')}"
            / f"{wc.get('embedding_method')}-{wc.get('sae')}",
        ),
    params:
        seqtype=lambda wc: wc.get("seqtype"),
        sae=lambda wc: wc.get("sae"),
        level=lambda wc: wc.get("level"),
        embedding_method=lambda wc: wc.get("embedding_method"),
        dataset_path=Path(DATASETS),
    output:
        directory(
            f"{DATASETS}/activations_{{seqtype}}_{{level}}/{{sae}}-{{embedding_method}}"
        ),


