from pathlib import Path
from env import SnakeEnv
import os


singularity: "../../image.sif"


configfile: "env.yaml"


env = SnakeEnv.new(config)

OUTDIR = env.outdir
DATASETS = env.datasets
NN = env.outdir / "nearest_neighbors"

os.environ["HF_HOME"] = env.huggingface

if not env.test:
    EMBEDDING_RES = env.resources["gpu40"]
    EMBEDDING_RES["time"] = env.slurm_time_limit
else:
    EMBEDDING_RES = {}


def get_wc(wildcard: str):
    def f(wc):
        return wc.get(wildcard)

    return f


out_list, named_out = env.get_outputs()


rule all:
    input:
        *out_list,


# TODO: record this pattern of using a base rule and inheritance if it works
rule base:
    params:
        seqtype=get_wc("seqtype"),
        level=get_wc("level"),
        method=get_wc("method"),
        variation=get_wc("variation"),
        sae=get_wc("sae"),
        embedding_method=get_wc("embedding_method"),
        pooling=get_wc("pooling"),
    script:
        "main.py"


# Total number of datasets is 2 * n_seqtypes *
# (n_variations * n_types_variation) * n_embedding_methods * n_pooling


use rule base as make_seq_dataset with:
    output:
        directory(f"{DATASETS}/sequences/{{seqtype}}-{{variation}}-{{method}}"),
        # Variation: random, natural, perturbed
        # Seqtypes: aa, nuc
        # `Method` refers to perturbation or randomization method. It's '0' for natural
        # sequences


use rule base as get_embeddings with:  # NOTE: this saves them as an embedding cache
    input:
        rules.make_seq_dataset.output,
    resources:
        **EMBEDDING_RES,
    output:
        f"{DATASETS}/embedded_{{seqtype}}_{{level}}/{{variation}}-{{method}}/{{embedding_method}}-{{pooling}}.completed",


use rule base as write_training_indices with:
    input:
        f"{DATASETS}/sequences/{{seqtype}}-natural-0",
    output:
        f"{OUTDIR}/training_indices/{{level}}_{{seqtype}}.json",


use rule base as label_cooccurrence with:
    input:
        env.metadata.file,
    params:
        tmp_file=f"{OUTDIR}/label_cooccur_tmp.csv",
    resources:
        mem="100g",
    output:
        f"{OUTDIR}/label_cooccurrence.csv",
        f"{OUTDIR}/cooccurrence_stats.yaml",


# rule evaluation:


# rule label_clustering:
#     input:
#         config["metadata"]["file"],
#     output:
#         f"{OUTDIR}/label_clusters_final.csv",
#         f"{OUTDIR}/label_cluster_stats.csv",
#     script:
#         "main.py"


use rule base as train_sae with:
    input:  # NOTE: Only train with natural sequences for now
        f"{DATASETS}/embedded_{{seqtype}}_{{level}}/natural-0/{{embedding_method}}-{{pooling}}.completed",
        f"{OUTDIR}/training_indices/{{level}}_{{seqtype}}.json",
    output:
        f"{OUTDIR}/saes_{{seqtype}}_{{level}}/{{embedding_method}}-{{pooling}}-{{sae}}.pt",


def is_pretrained(wc):
    return wc.get("sae") in (env.saes["pretrained"] or [])


use rule base as get_activations with:
    input:
        embeddings=branch(
            is_pretrained,
            then=f"{DATASETS}/sequences/{{seqtype}}-natural-0",
            otherwise=f"{DATASETS}/sequences/{{seqtype}}-natural-0",
        ),
        sae=branch(
            is_pretrained,
            then=None,
            otherwise=lambda wc: OUTDIR
            / f"saes_{wc['seqtype']}_{wc['level']}"
            / f"{wc['embedding_method']}-{wc['pooling']}-{wc['sae']}.pt",
        ),
    output:
        directory(
            f"{DATASETS}/activations_{{seqtype}}_{{level}}/{{embedding_method}}-{{pooling}}-{{sae}}"
        ),


use rule base as nearest_neighbors with:
    input:
        f"{DATASETS}/embedded_{{seqtype}}_{{level}}/natural-0/{{embedding_method}}-{{pooling}}.completed",
    output:
        f"{NN}/{{seqtype}}_{{level}}/{{embedding_method}}-{{pooling}}.csv",
        directory(f"{NN}/{{seqtype}}_{{level}}/{{embedding_method}}-{{pooling}}"),


