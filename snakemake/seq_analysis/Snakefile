from pathlib import Path
from env import SnakeEnv
import os


configfile: "env.yaml"


env = SnakeEnv.new(config)

OUTDIR = env.outdir
DATASETS = env.datasets

os.environ["HF_HOME"] = env.huggingface

EMBEDDING_RES = env.resources["gpu40"]
EMBEDDING_RES["time"] = env.slurm_time_limit


rule all:
    input:
        *env.get_outputs(),


rule make_seq_dataset:
    params:
        seqtype=lambda wc: wc.get("seqtype"),
    output:
        directory(f"{DATASETS}/sequence_{{seqtype}}"),
    script:
        "main.py"


# rule make_control_datasets


rule get_embeddings:  # NOTE: this saves them as an embedding cache
    input:
        rules.make_seq_dataset.output,
    params:
        seqtype=lambda wc: wc.get("seqtype"),
        level=lambda wc: wc.get("level"),
        embedding_method=lambda wc: wc.get("embedding_method"),
    resources:
        **EMBEDDING_RES,
    output:
        f"{DATASETS}/embedded_{{seqtype}}_{{level}}/{{embedding_method}}.completed",
    script:
        "main.py"


rule write_training_indices:
    input:
        rules.make_seq_dataset.output,
    params:
        seqtype=lambda wc: wc.get("seqtype"),
        level=lambda wc: wc.get("level"),
        dataset_path=Path(DATASETS),
    output:
        f"{OUTDIR}/training_indices/{{level}}_{{seqtype}}.json",
    script:
        "main.py"


rule train_sae:
    input:
        rules.get_embeddings.output,
        f"{OUTDIR}/training_indices/{{level}}_{{seqtype}}.json",
    params:
        seqtype=lambda wc: wc.get("seqtype"),
        sae=lambda wc: wc.get("sae"),
        embedding_method=lambda wc: wc.get("embedding_method"),
        level=lambda wc: wc.get("level"),
        dataset_path=Path(DATASETS),
    output:
        f"{OUTDIR}/saes_{{seqtype}}_{{level}}/{{embedding_method}}-{{sae}}.pt",


rule label_cooccurrence:
    input:
        env.metadata.file,
    params:
        tmp_file=f"{OUTDIR}/label_cooccur_tmp.csv",
    output:
        f"{OUTDIR}/label_cooccurrence.csv",
        f"{OUTDIR}/cooccurrence_stats.yaml",
    script:
        "main.py"


